# Internet deployment — copy to .env
# docker compose -f compose.internet.yaml up -d
# First visit: https://your-server/setup

TZ=Europe/Moscow
KMS_VERSION=1.9.0
GUI_VERSION=1.9.0

# KMS: public
KMS_BIND=0.0.0.0
KMS_PORT=1688
KMS_LOGLEVEL=INFO

# GUI: public (app login required — INTERNET_MODE enforces this)
GUI_BIND=0.0.0.0
GUI_PORT=443
GUI_AUTH_ENABLED=true
API_AUTH_REQUIRED=true
OPS_DOCKER_ENABLED=true

# Low-RAM VPS stability (recommended for ≤1 GB RAM)
GUNICORN_PRELOAD=false
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=300
GUNICORN_MAX_REQUESTS=0

# TLS — cert.pem + key.pem in ./certs/
NGINX_TLS_ENABLED=true
TLS_CERT_DIR=./certs

# Webhooks (optional)
# WEBHOOK_URL=https://example.com/hook
# WEBHOOK_SECRET=change-me
# WEBHOOK_EVENTS=client_new,client_unhealthy
# WEBHOOK_INTERVAL=60

# Startup (low-RAM VPS: set GUNICORN_PRELOAD=false for faster cold start)
# GUNICORN_PRELOAD=false
# GUNICORN_STARTUP_TIMEOUT=180
