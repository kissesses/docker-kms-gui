# Internet deployment — copy to .env
# docker compose -f compose.internet.yaml up -d
# First visit: https://your-server/setup

TZ=Europe/Moscow
KMS_VERSION=1.7.0
GUI_VERSION=1.7.0

# KMS: public
KMS_BIND=0.0.0.0
KMS_PORT=1688

# GUI: public (protected by app login at /setup then /login)
GUI_BIND=0.0.0.0
GUI_PORT=443

# Application auth (admin created at /setup on first run)
GUI_AUTH_ENABLED=true

# TLS — required for internet (cert.pem + key.pem in ./certs/)
NGINX_TLS_ENABLED=true
TLS_CERT_DIR=./certs

KMS_LOGLEVEL=INFO
KMS_GUI_STYLE=custom-icon
