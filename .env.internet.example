# Internet deployment — copy to .env
# docker compose -f compose.internet.yaml up -d

TZ=Europe/Moscow
KMS_VERSION=1.6.1
GUI_VERSION=1.6.1

# KMS: public (clients connect from internet)
KMS_BIND=0.0.0.0
KMS_PORT=1688

# GUI: localhost only — use SSH tunnel or Tailscale to access dashboard
GUI_BIND=127.0.0.1
GUI_PORT=443

# Required — strong password (12+ chars)
NGINX_BASIC_AUTH_USER=admin
NGINX_BASIC_AUTH_PASS=change-me-to-a-long-random-password

# TLS certs directory (cert.pem + key.pem inside)
NGINX_TLS_ENABLED=true
TLS_CERT_DIR=./certs

KMS_LOGLEVEL=INFO
KMS_GUI_STYLE=custom-icon
