# Copy to .env and adjust
TZ=Europe/Moscow

# Versions (used in compose image tags)
KMS_VERSION=1.7.0
GUI_VERSION=1.7.0

# Bind to localhost only (recommended for personal use)
# Use 0.0.0.0 to allow LAN access; or KMS_BIND / GUI_BIND separately
BIND_ADDRESS=127.0.0.1
# KMS_BIND=0.0.0.0
# GUI_BIND=127.0.0.1

# Ports
KMS_PORT=1688
GUI_PORT=80

# KMS server
KMS_LOGLEVEL=INFO

# Web GUI
KMS_GUI_STYLE=custom-icon
NGINX_ENABLED=true
DEBUG=

# Recommended: protect web UI with basic auth (or use GUI_AUTH_ENABLED=true)
NGINX_BASIC_AUTH_USER=
NGINX_BASIC_AUTH_PASS=

# Application login (setup at /setup on first run)
GUI_AUTH_ENABLED=false

# Optional: TLS (mount certs to gui container at /etc/nginx/certs/)
NGINX_TLS_ENABLED=false
