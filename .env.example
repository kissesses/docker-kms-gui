# Copy to .env and adjust: cp .env.example .env
# Start: docker compose up -d

# ── General ──────────────────────────────────────────────────────────────
TZ=Europe/Moscow
KMS_VERSION=1.8.0
GUI_VERSION=1.8.0

# ── Network bind (host) ────────────────────────────────────────────────────
# Default: localhost only. Override KMS_BIND / GUI_BIND per service (LAN/internet).
BIND_ADDRESS=127.0.0.1
KMS_BIND=127.0.0.1
GUI_BIND=127.0.0.1
# KMS_BIND=0.0.0.0
# GUI_BIND=127.0.0.1

KMS_PORT=1688
GUI_PORT=80

# ── KMS server ───────────────────────────────────────────────────────────
KMS_LOGLEVEL=INFO
KMS_CLIENT_COUNT=26
KMS_ACTIVATION_INTERVAL=120
KMS_RENEWAL_INTERVAL=10080
KMS_HWID=RANDOM

# ── Web GUI ──────────────────────────────────────────────────────────────
NGINX_ENABLED=true

# Auth option A: application login (/setup on first run)
GUI_AUTH_ENABLED=false

# Show /admin when auth is disabled (default: false — admin hidden without login)
ADMIN_PUBLIC=false

# Protect /api/* (default: same as GUI_AUTH_ENABLED; forced on when INTERNET_MODE=true)
# API_AUTH_REQUIRED=true
# Optional Bearer token for scripts: Authorization: Bearer <token>
# GUI_API_TOKEN=

# Auth option B: nginx basic auth (leave empty if using GUI_AUTH_ENABLED=true)
NGINX_BASIC_AUTH_USER=
NGINX_BASIC_AUTH_PASS=

# Debug Flask/gunicorn logs (do not use on internet)
DEBUG=

# ── TLS (optional) ───────────────────────────────────────────────────────
# Mount cert.pem + key.pem to ./certs/ and expose port 443 in compose if needed.
NGINX_TLS_ENABLED=false
TLS_CERT_DIR=./certs
