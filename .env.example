# Copy to .env: cp .env.example .env
# Local/LAN:  docker compose up -d
# Internet:   docker compose -f compose.internet.yaml up -d
# Or use:      ./scripts/install.sh --mode local|lan|internet

# ── General ──────────────────────────────────────────────────────────────
TZ=Europe/Moscow
KMS_VERSION=1.10.0
GUI_VERSION=1.10.0

# ── Network bind (host) ────────────────────────────────────────────────────
# local:  127.0.0.1 / 127.0.0.1
# lan:    KMS_BIND=0.0.0.0, GUI_BIND=127.0.0.1
# internet: KMS_BIND=0.0.0.0, GUI_BIND=0.0.0.0, GUI_PORT=443
BIND_ADDRESS=127.0.0.1
KMS_BIND=127.0.0.1
GUI_BIND=127.0.0.1
KMS_PORT=1688
GUI_PORT=80

# ── KMS server ───────────────────────────────────────────────────────────
KMS_LOGLEVEL=INFO
KMS_CLIENT_COUNT=26
KMS_ACTIVATION_INTERVAL=120
KMS_RENEWAL_INTERVAL=10080
KMS_HWID=RANDOM

# ── Web GUI ──────────────────────────────────────────────────────────────
NGINX_ENABLED=true

# Interface language: en | ru (also toggle RU/EN in the header)
# GUI_DEFAULT_LANG=ru

# Auth: application login (/setup on first run)
GUI_AUTH_ENABLED=false
ADMIN_PUBLIC=false
KEYS_PUBLIC=true

# API protection (auto on with GUI_AUTH_ENABLED, TLS, or INTERNET_MODE)
# API_AUTH_REQUIRED=true
# API_PUBLIC=true
# GUI_API_TOKEN=

# Admin → Operations: restart KMS from GUI (internet compose mounts docker.sock)
OPS_DOCKER_ENABLED=false

# nginx basic auth (alternative to GUI_AUTH_ENABLED)
NGINX_BASIC_AUTH_USER=
NGINX_BASIC_AUTH_PASS=

# Debug (never on internet)
DEBUG=

# ── TLS (internet / optional) ────────────────────────────────────────────
# cert.pem + key.pem in TLS_CERT_DIR; use compose.internet.yaml for :443
NGINX_TLS_ENABLED=false
TLS_CERT_DIR=./certs

# ── Gunicorn (recommended for internet / low-RAM VPS) ──────────────────────
# install.sh sets these automatically for --mode internet
GUNICORN_PRELOAD=false
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=300
GUNICORN_MAX_REQUESTS=0
# GUNICORN_STARTUP_TIMEOUT=120

# ── Webhooks (optional) ────────────────────────────────────────────────────
# WEBHOOK_URL=https://example.com/hook
# WEBHOOK_SECRET=change-me
# WEBHOOK_EVENTS=client_new,client_unhealthy
# WEBHOOK_INTERVAL=60
