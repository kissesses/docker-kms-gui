# Copy to .env: cp .env.example .env
# Configure mode: ./scripts/install.sh --mode local|lan|internet
# Start:          docker compose up -d

# ── Deploy mode (set by install.sh or manually) ───────────────────────────
# local / lan: INTERNET_MODE=false
# internet:    INTERNET_MODE=true
INTERNET_MODE=false

# ── General ──────────────────────────────────────────────────────────────
TZ=Europe/Moscow
KMS_VERSION=1.10.0
GUI_VERSION=1.10.0

# ── Network bind (host) ────────────────────────────────────────────────────
# local:    127.0.0.1 / 127.0.0.1
# lan:      KMS_BIND=0.0.0.0, GUI_BIND=127.0.0.1
# internet: KMS_BIND=0.0.0.0, GUI_BIND=0.0.0.0, NGINX_TLS_ENABLED=true
BIND_ADDRESS=127.0.0.1
KMS_BIND=127.0.0.1
GUI_BIND=127.0.0.1
KMS_PORT=1688
GUI_HTTP_PORT=80
GUI_TLS_PORT=443

# ── KMS server ───────────────────────────────────────────────────────────
KMS_LOGLEVEL=INFO
KMS_CLIENT_COUNT=26
KMS_ACTIVATION_INTERVAL=120
KMS_RENEWAL_INTERVAL=10080
KMS_HWID=RANDOM

# ── Web GUI ──────────────────────────────────────────────────────────────
NGINX_ENABLED=true

# Interface language: en | ru (also toggle RU/EN in the header)
# GUI_DEFAULT_LANG=ru

GUI_AUTH_ENABLED=false
ADMIN_PUBLIC=false
KEYS_PUBLIC=true

# API protection (auto on with GUI_AUTH_ENABLED, TLS, or INTERNET_MODE)
# API_AUTH_REQUIRED=true
# API_PUBLIC=true
# GUI_API_TOKEN=

# Admin → Operations: restart KMS from GUI (needs docker.sock mount)
OPS_DOCKER_ENABLED=false

NGINX_BASIC_AUTH_USER=
NGINX_BASIC_AUTH_PASS=

DEBUG=

# ── TLS (internet) ───────────────────────────────────────────────────────
# cert.pem + key.pem in TLS_CERT_DIR
NGINX_TLS_ENABLED=false
TLS_CERT_DIR=./certs

# ── Gunicorn (internet / low-RAM VPS) ────────────────────────────────────
GUNICORN_PRELOAD=false
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=300
GUNICORN_MAX_REQUESTS=0
# GUNICORN_STARTUP_TIMEOUT=120

# ── Webhooks (optional) ────────────────────────────────────────────────────
# WEBHOOK_URL=https://example.com/hook
# WEBHOOK_SECRET=change-me
# WEBHOOK_EVENTS=client_new,client_unhealthy
# WEBHOOK_INTERVAL=60
